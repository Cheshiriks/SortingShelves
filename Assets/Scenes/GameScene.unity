      \u043C\u0435\u043D\u044F \u0442\u0443\u0442 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
      \u0431\u0435\u0441\u043F\u043E\u0440\u044F\u0434\u043E\u043A \u043D\u0430 \u043F\u043E\u043B\u043A\u0430\u0445\u2026
      \u041F\u043E\u043C\u043E\u0436\u0435\u0448\u044C \u043C\u043D\u0435 \u0432\u0441\u0451
      \u0440\u0430\u0441\u0441\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C?"
    LineEng: 
  - LineRus: "\u041D\u0443\u0436\u043D\u043E \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C
      \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B\u0435 \u0432\u0435\u0449\u0438
      \u043F\u043E \u043C\u0435\u0441\u0442\u0430\u043C.\n\u041A\u043E\u0433\u0434\u0430
      \u043D\u0430 \u043F\u043E\u043B\u043A\u0430\u0445 \u0431\u0443\u0434\u0435\u0442
      \u043F\u043E\u0440\u044F\u0434\u043E\u043A, \u043C\u044B \u0441\u043C\u043E\u0436\u0435\u043C
      \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C \u043C\u0435\u0441\u0442\u043E
      \u0434\u043B\u044F \u043D\u043E\u0432\u044B\u0445 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432."
    LineEng: 
  - LineRus: "\u0414\u0430\u0432\u0430\u0439 \u043D\u0430\u0447\u043D\u0435\u043C
      \u0441 \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E.\n\u042F
      \u0443\u0432\u0435\u0440\u0435\u043D\u0430, \u0443 \u043D\u0430\u0441 \u0432\u0441\u0451
      \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0441\u044F!"
    LineEng: 
  playOnEnable: 1
  playOnlyOnce: 0
